# Production environment variables for Pensieve app
# Copy this to .env.production (or set directly in your hosting provider)
# Values below are from Terraform outputs

# API Gateway endpoint (used by CLI, not the app directly)
NEXT_PUBLIC_API_URL=https://a65q1v78o5.execute-api.us-east-1.amazonaws.com

# CloudFront CDN for serving synced content
NEXT_PUBLIC_CLOUDFRONT_URL=https://d1ev96uvalo97d.cloudfront.net

# AWS
AWS_REGION=us-east-1
AWS_S3_BUCKET=pensieve-content-931097097534

# DynamoDB (real AWS — do NOT set DYNAMODB_ENDPOINT in prod)
DYNAMODB_LEXICONS_TABLE=pensieve-lexicons
DYNAMODB_USERS_TABLE=pensieve-users

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET

# AWS credentials — only needed if NOT running on ECS/EC2/Lambda with IAM role
# If deploying to Vercel, create an IAM user with DynamoDB+S3 read access and fill these in
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
